[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://Scripts/Menus/mechanics_menu.gd" id="1"]

[node name="MechanicsMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="MainVBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 10.0
offset_top = 10.0
offset_right = -10.0
offset_bottom = -10.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

# Note: When embedded in a tab, the script hides TitleLabel, VehicleOptionButton,
# and BackButton to better match the style of other tabs.

[node name="TitleLabel" type="Label" parent="MainVBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 20
text = "Mechanic"

[node name="VehicleOptionButton" type="OptionButton" parent="MainVBox"]
layout_mode = 2
size_flags_horizontal = 3

	[node name="TabsRow" type="HBoxContainer" parent="MainVBox"]
	layout_mode = 2
	theme_override_constants/separation = 10

	[node name="TabScroll" type="ScrollContainer" parent="MainVBox/TabsRow"]
	layout_mode = 2
	size_flags_horizontal = 3
	vertical_scroll_mode = 0

	[node name="TabHBox" type="HBoxContainer" parent="MainVBox/TabsRow/TabScroll"]
	layout_mode = 2
	size_flags_horizontal = 3
	theme_override_constants/separation = 10

	[node name="ContextButtons" type="HBoxContainer" parent="MainVBox/TabsRow"]
	layout_mode = 2
	theme_override_constants/separation = 10

	[node name="ApplyButton" type="Button" parent="MainVBox/TabsRow/ContextButtons"]
	layout_mode = 2
	size_flags_horizontal = 3
	text = "Apply Changes"

	[node name="TabContainer" type="TabContainer" parent="MainVBox"]
	layout_mode = 2
	size_flags_vertical = 3
	tabs_visible = false

	[node name="Parts" type="ScrollContainer" parent="MainVBox/TabContainer"]
	layout_mode = 2

	[node name="PartsVBox" type="VBoxContainer" parent="MainVBox/TabContainer/Parts"]
	layout_mode = 2
	size_flags_horizontal = 3
	size_flags_vertical = 3

	[node name="Pending" type="ScrollContainer" parent="MainVBox/TabContainer"]
	layout_mode = 2

	[node name="PendingVBox" type="VBoxContainer" parent="MainVBox/TabContainer/Pending"]
	layout_mode = 2
	size_flags_horizontal = 3
	size_flags_vertical = 3

	[node name="BottomBar" type="HBoxContainer" parent="MainVBox"]
	layout_mode = 2

	[node name="BackButton" type="Button" parent="MainVBox/BottomBar"]
	layout_mode = 2
	size_flags_horizontal = 3
	text = "Back"

